# Google Cloud API Key (optional, for Google AI services)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key (optional, for text-to-video via Runway or similar)
OPENAI_API_KEY=your_openai_api_key_here

# Replicate API Key (for open-source video generation models)
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Runway API Key (optional, for advanced video generation)
RUNWAY_API_KEY=your_runway_api_key_here

# Next.js Environment Variables
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
